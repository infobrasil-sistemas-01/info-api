generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String        @id @default(uuid())
  user            String        @unique @db.VarChar(78)
  passwordHash    String        @map("password_hash") @db.VarChar(255)
  status          Boolean       @default(true)
  dbCredentialsId String        @map("db_credentials_id")
  email           String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  storeId         Int           @default(1) @map("store_id")
  roleId          String?       @map("role_id")
  planId          String?       @map("plan_id")
  dbCredentials   DbCredentials @relation(fields: [dbCredentialsId], references: [id])
  role            Role?         @relation(fields: [roleId], references: [id])
  plan            Plan?         @relation(fields: [planId], references: [id])
  invitation      UserInvitation?
  requestLogs     RequestLog[]
  announcementViews AnnouncementView[]

  @@map("users")
}

model Plan {
  id               String   @id @default(uuid())
  name             String   @unique
  reqMin           Int      @map("req_min")
  reqMonth         Int      @map("req_month")
  maxPageSize      Int      @map("max_page_size")
  maxDateRangeDays Int      @map("max_date_range_days")
  users            User[]

  @@map("plans")
}

model RequestLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  method    String
  path      String
  status    Int
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("request_logs")
}

model UserInvitation {
  id         String    @id @default(uuid())
  userId     String    @unique @map("user_id")
  token      String    @unique
  createdAt  DateTime  @default(now()) @map("created_at")
  expiresAt  DateTime  @map("expires_at")
  acceptedAt DateTime? @map("accepted_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_invitations")
}

model DbCredentials {
  id       String @id @default(uuid())
  host     String
  port     Int
  database String
  user     String
  dbId     Int    @map("db_id")
  users    User[]

  @@map("db_credentials")
}

model Role {
  id              String           @id @default(uuid())
  name            String           @db.VarChar(50)
  description     String?          @db.VarChar(255)
  rolePermissions RolePermission[]
  users           User[]

  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid())
  key             String           @unique @db.VarChar(100)
  name            String           @db.VarChar(50)
  description     String?          @db.VarChar(255)
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model IntegrationRequest {
  id                String      @id @default(uuid())
  clientName        String      @map("client_name")
  hostingType       HostingType @map("hosting_type")
  fixedIp           String?     @map("fixed_ip")
  database          Json
  scopes            Json
  objective         String
  technicalContact  Json        @map("technical_contact")
  responsiblePerson Json        @default("{}") @map("responsible_person")
  status            String      @default("PENDING")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  modules           String[]
  cnpj              String?
  legalName         String      @map("legal_name")
  rejectionReason   String?     @map("rejection_reason")

  @@map("integration_requests")
}

enum HostingType {
  DATACENTER
  CLIENT_SERVER
}

enum AnnouncementType {
  DOC
  INFO
  WARNING
  ALERT
}

model Announcement {
  id           String           @id @default(uuid())
  type         AnnouncementType @default(INFO)
  text         String           @db.Text
  ctaText      String?          @map("cta_text") @db.VarChar(50)
  ctaLink      String?          @map("cta_link") @db.VarChar(255)
  startDate    DateTime?        @map("start_date")
  endDate      DateTime?        @map("end_date")
  active       Boolean          @default(true)
  newsletterId Int?             @map("newsletter_id")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  views        AnnouncementView[]
  newsletter   Newsletter?      @relation(fields: [newsletterId], references: [id], onDelete: SetNull)

  @@map("announcements")
}

model Newsletter {
  id             Int            @id @default(autoincrement())
  subject        String         @db.VarChar(255)
  initialMessage String?        @map("initial_message") @db.Text
  finalMessage   String?        @map("final_message") @db.Text
  sentAt         DateTime       @default(now()) @map("sent_at")
  announcements  Announcement[]

  @@map("newsletters")
}

model AnnouncementView {
  id             String       @id @default(uuid())
  announcementId String       @map("announcement_id")
  userId         String       @map("user_id")
  viewedAt       DateTime     @default(now()) @map("viewed_at")
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@map("announcement_views")
}

model StatusLog {
  id         String   @id @default(uuid())
  apiStatus  String   @db.VarChar(10) // "UP" ou "DOWN"
  apiLatency Int
  dbStatus   String   @db.VarChar(10) // "UP" ou "DOWN"
  dbLatency  Int
  timestamp  DateTime @default(now()) @map("timestamp")

  @@index([timestamp])
  @@map("status_logs")
}
