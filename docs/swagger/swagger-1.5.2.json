    "/products": {
      "get": {
        "description": "Retorna uma lista paginada de produtos associados às credenciais do usuário autenticado.",
        "operationId": "ProductController_getProducts",
        "parameters": [
          {
            "name": "page",
            "required": false,
            "in": "query",
            "description": "Número de página para paginação",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "pageSize",
            "required": false,
            "in": "query",
            "description": "Número de itens por página",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "group",
            "required": false,
            "in": "query",
            "description": "Código do grupo para filtrar produtos",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "brand",
            "required": false,
            "in": "query",
            "description": "Código da marca para filtrar produtos",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "minStock",
            "required": false,
            "in": "query",
            "description": "Quantidade mínima em estoque para filtrar produtos",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "search",
            "required": false,
            "in": "query",
            "description": "Termo de busca para filtrar produtos por descrição",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de produtos retornada com sucesso.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "PRO_CODIGO": {
                        "type": "number",
                        "example": 101
                      },
                      "PRO_CODIGOBAR": {
                        "type": "string",
                        "example": "7891234567890"
                      },
                      "PRO_DESCRICAO": {
                        "type": "string",
                        "example": "Produto Exemplo"
                      },
                      "MAR_CODIGO": {
                        "type": "number",
                        "example": 1
                      },
                      "MAR_DESCRICAO": {
                        "type": "string",
                        "example": "Marca Exemplo"
                      },
                      "GRU_CODIGO": {
                        "type": "number",
                        "example": 1
                      },
                      "GRU_DESCRICAO": {
                        "type": "string",
                        "example": "Grupo Exemplo"
                      },
                      "EST_ATUAL": {
                        "type": "number",
                        "example": 50
                      },
                      "EST_APOIO": {
                        "type": "number",
                        "example": 50
                      },
                      "PRECO": {
                        "type": "number",
                        "example": 19.99
                      },
                      "PRECO2": {
                        "type": "number",
                        "example": 17.5
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Erro de requisição, como pageSize excedendo o limite."
          },
          "401": {
            "description": "Token de autenticação inválido ou ausente."
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Listar produtos",
        "tags": [
          "Product"
        ]
      }
    },
