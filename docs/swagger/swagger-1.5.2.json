  "info": {
    "title": "InfoBrasil API",
    "description": "API de integração do sistema Retaguarda (by InfoBrasil) com outros sistemas, como ERPs, e-commerce, etc. <br><br>\n      Se deseja solicitar um acesso, preencha o formulário em: <a href='https://info-api.infobrasilsistemas.com.br/integration/form'>Solicitar Acesso</a>\n      <br><br>\n      **O sistema conta com duas formas de autenticação:**<br> \n      - Basic Auth para login e obtenção de token JWT<br>\n      - JWT para acesso aos endpoints protegidos.\n      <br><br>\n      Para verificar a disponibilidade da API acesse nossa <a href='/status'>Página de Status</a>\n      <br><br>\n      A API é organizada em módulos, cada um responsável por uma área específica do sistema, como produtos, clientes, vendas, etc.",
    "version": "1.5.2",
    "contact": {
      "name": "InfoBrasil Sistemas",
      "url": "https://www.infobrasilsistemas.com.br",
      "email": "suporte@infobrasilsistemas.com.br"
    }
  },
  "tags": [
    {
      "name": "Auth",
      "description": "Endpoints relacionados à autenticação e obtenção de token JWT"
    },
    {
      "name": "Product",
      "description": "Endpoints relacionados à gestão de produtos"
    },
    {
      "name": "Product / Brand",
      "description": "Endpoints relacionados à gestão de marcas e produtos vinculados a marcas"
    },
    {
      "name": "Product / Group",
      "description": "Endpoints relacionados à gestão de grupos e produtos vinculados a grupos"
    },
    {
      "name": "PaymentMethod",
      "description": "Endpoints relacionados à gestão de meios de pagamento"
    },
    {
      "name": "Order",
      "description": "Endpoints relacionados à gestão de pedidos"
    },
    {
      "name": "AccountReceivable",
      "description": "Endpoints relacionados à gestão de contas a receber"
    }
  ],
  "servers": [
    {
      "url": "http://localhost:3336",
      "description": "Servidor local para desenvolvimento"
    },
    {
      "url": "https://info-api.infobrasilsistemas.com.br",
      "description": "Servidor de produção"
    }
  ],
  "components": {
    "securitySchemes": {
      "basic": {
        "type": "http",
        "scheme": "basic"
      },
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RefreshDto": {
        "type": "object",
        "properties": {
          "refresh_token": {
            "type": "string",
            "description": "Token de refresh para obter um novo token de acesso"
          }
        },
        "required": [
          "refresh_token"
        ]
      },
      "SoldProductDto": {
        "type": "object",
        "properties": {
          "product_id": {
            "type": "number",
            "description": "ID do produto"
          },
          "quantity": {
            "type": "number",
            "description": "Quantidade vendida"
          },
          "variant_id": {
            "type": "number",
            "description": "ID da variante do produto"
          }
        },
        "required": [
          "product_id",
          "quantity"
        ]
      },
      "PostOrderDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "description": "ID do pedido"
          },
          "date": {
            "type": "string",
            "description": "Data do pedido"
          },
          "hour": {
            "type": "string",
            "description": "Hora do pedido"
          },
          "taxes": {
            "type": "number",
            "description": "Valor de acréscimo/taxa"
          },
          "discount": {
            "type": "number",
            "description": "Valor de desconto"
          },
          "store_note": {
            "type": "string",
            "description": "Informações adicionais da loja"
          },
          "payment_method_rate": {
            "type": "number",
            "description": "Taxa do meio de pagamento"
          },
          "installment": {
            "type": "number",
            "description": "Quantidade de parcelas (apenas para meios de pagamento com parcelamento)"
          },
          "payment_method": {
            "type": "string",
            "description": "Meio de pagamento"
          },
          "payment_date": {
            "type": "string",
            "description": "Data de pagamento"
          },
          "interest": {
            "type": "number",
            "description": "Juros do pedido"
          },
          "has_payment": {
            "type": "boolean",
            "description": "Indica se existe pagamento confirmado"
          },
          "has_invoice": {
            "type": "boolean",
            "description": "Indica se existe nota fiscal"
          },
          "products_sold": {
            "description": "Lista de produtos vendidos",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SoldProductDto"
            }
          }
        },
        "required": [
          "id",
          "date",
          "hour",
          "payment_method",
          "payment_date",
          "has_payment",
          "has_invoice"
        ]
      },
      "GenerateReceiptDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "Email do cliente para envio do cupom fiscal"
          },
          "cpf": {
            "type": "string",
            "description": "CPF do cliente (opcional, para fins fiscais)"
          }
        },
        "required": [
          "email",
          "cpf"
        ]
      }
    }
  }
}